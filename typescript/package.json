{
  "name": "memory-manager",
  "version": "1.0.2",
  "description": "Production-grade tiered AI Memory Management System",
  "type": "module",
  "main": "./dist/memoryManager.js",
  "types": "./dist/memoryManager.d.ts",
  "exports": {
    ".": {
      "import": "./dist/memoryManager.js",
      "types":  "./dist/memoryManager.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.js",
      "types":  "./dist/agent.d.ts"
    }
  },
  "scripts": {
    "build":  "tsc",
    "dev":    "npx ts-node --esm src/agent.ts",
    "start":  "node dist/agent.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": { "node": ">=18.0.0" },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node":    "^10.9.0"
  }
}
